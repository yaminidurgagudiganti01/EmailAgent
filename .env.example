# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# gpt-4o-mini (fast + cheap) or gpt-4o (better quality)
OPENAI_MODEL=gpt-4o-mini

# ── Gmail OAuth ───────────────────────────────────────────────────────────────
# Download OAuth client JSON from Google Cloud Console → Credentials → Desktop app
GMAIL_CREDENTIALS_PATH=./config/credentials.json
GMAIL_TOKEN_PATH=./config/token.json

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase: Settings → Database → Connection string → URI (use the pooler URL in prod)
# Leave empty to fall back to local SQLite (./data/processed.db)
DATABASE_URL=

# ── Agent settings ────────────────────────────────────────────────────────────
MAX_EMAILS_PER_RUN=10
INBOX_QUERY=is:unread -category:promotions -category:social
USER_NAME=Your Name
USER_SIGNATURE=Best,\nYour Name

# ── Observability ─────────────────────────────────────────────────────────────
# "text" for human-readable console output, "json" for log aggregators
LOG_FORMAT=text
LOG_DIR=./logs
