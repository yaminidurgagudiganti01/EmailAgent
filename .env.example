# OpenAI configuration
OPENAI_API_KEY=sk-...
# Recommended: gpt-4o-mini (fast + cheap) or gpt-4o (better reasoning)
OPENAI_MODEL=gpt-4o-mini

# Gmail OAuth (downloaded from Google Cloud Console)
GMAIL_CREDENTIALS_PATH=./config/credentials.json
GMAIL_TOKEN_PATH=./config/token.json

# Agent settings
MAX_EMAILS_PER_RUN=10
INBOX_QUERY=is:unread -category:promotions -category:social
USER_NAME=Your Name
USER_SIGNATURE=Best,\nYour Name
